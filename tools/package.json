{
  "name": "seo-geo-mcp-servers",
  "version": "1.0.0",
  "description": "MCP servers for SEO & GEO Skills Library",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:contracts": "vitest run --project contracts",
    "test:orchestration": "vitest run --project orchestration",
    "test:e2e": "RUN_E2E=true vitest run --project e2e",
    "test:caplinq": "RUN_E2E=true vitest run --grep caplinq",
    "test:all": "npm run test && npm run test:contracts && npm run test:orchestration"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.0.0",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "msw": "^2.8.0",
    "yaml": "^2.7.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
